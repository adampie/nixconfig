amends "package://github.com/jdx/hk/releases/download/v1.38.0/hk@1.38.0#/Config.pkl"

local linters = new Mapping<String, Step> {
  ["nix_fmt"] {
    glob = List("*.nix")
    check = "nix fmt . -- --check"
    fix = "nix fmt ."
  }
  ["flake_check"] {
    check = "nix flake check --all-systems"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    steps = linters
  }
}
